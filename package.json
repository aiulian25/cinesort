{
  "name": "cinesort",
  "version": "1.3.0",
  "description": "CineSort - Professional media file organizer with smart metadata matching",
  "main": "electron/main.js",
  "author": {
    "name": "CineSort",
    "email": "app@cinesort.local"
  },
  "homepage": "https://github.com/cinesort/cinesort",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "docker:build": "docker build --build-arg PYTHON_VERSION=3.11 -t cinesort:latest -t cinesort:$npm_package_version .",
    "docker:setup": "[ -e /proc/sys/fs/binfmt_misc/qemu-aarch64 ] || docker run --rm --privileged tonistiigi/binfmt --install arm64; docker buildx inspect cinesort-builder >/dev/null 2>&1 || docker buildx create --name cinesort-builder --driver docker-container --bootstrap",
    "docker:release": "npm run docker:setup && docker buildx build --builder cinesort-builder --platform linux/amd64,linux/arm64 --build-arg PYTHON_VERSION=3.11 -t aiulian25/cinesort:$npm_package_version -t aiulian25/cinesort:latest --push .",
    "gh:upload": "gh release upload v$npm_package_version dist/CineSort-$npm_package_version.AppImage dist/CineSort-$npm_package_version-arm64.AppImage dist/cinesort_${npm_package_version}_amd64.deb dist/cinesort_${npm_package_version}_arm64.deb dist/cinesort-$npm_package_version.x86_64.rpm dist/cinesort-$npm_package_version.aarch64.rpm --clobber",
    "release": "npm run build && npm run docker:release && npm run gh:upload"
  },
  "build": {
    "appId": "com.cinesort.app",
    "productName": "CineSort",
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64", "arm64"] },
        { "target": "rpm",      "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icons",
      "synopsis": "Professional media file organizer",
      "description": "CineSort - Smart media file renaming with TMDb and TVmaze integration",
      "category": "AudioVideo",
      "desktop": {
        "Comment": "Professional media file organizer",
        "Categories": "AudioVideo;Video;Utility;",
        "StartupWMClass": "CineSort",
        "StartupNotify": "true"
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0", "libnotify4", "libnss3",
        "libxss1", "libxtst6", "xdg-utils",
        "libatspi2.0-0", "libuuid1", "python3"
      ],
      "afterInstall": "build/postinst.sh",
      "afterRemove": "build/postrm.sh"
    },
    "rpm": {
      "depends": [
        "gtk3", "libnotify", "nss",
        "libXScrnSaver", "libXtst", "xdg-utils",
        "at-spi2-core", "libuuid", "python3"
      ],
      "afterInstall": "build/postinst.sh",
      "afterRemove": "build/postrm.sh"
    },
    "files": [
      "electron/**/*",
      "app/**/*",
      "!app/__pycache__/**",
      "!**/*.pyc"
    ],
    "extraResources": [
      { "from": ".venv", "to": "venv", "filter": ["**/*"] },
      { "from": "requirements.txt", "to": "requirements.txt" }
    ],
    "asar": false
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
